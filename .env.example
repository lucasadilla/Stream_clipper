# --- Supabase (recommended) ---
# Transaction pooler — use for the running app (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for Prisma migrations / db push (port 5432)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Local PostgreSQL (alternative) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stream_clipper?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/stream_clipper?schema=public"

# OpenAI (direct API — optional if using OpenRouter)
OPENAI_API_KEY=""

# OpenRouter (cheaper chat + optional Whisper/embeddings; OpenAI-compatible SDK)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# OPENROUTER_CHAT_MODEL="google/gemini-2.5-flash-lite"
# OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
# OPENROUTER_WHISPER_MODEL="openai/whisper-large-v3"  # supports word/segment timestamps via verbose_json
# WHISPER_PROVIDER="openrouter"  # default when OPENROUTER_API_KEY is set; use "openai" for direct API
# OPENAI_TRANSCRIPTION_QUALITY_MODEL="gpt-4o-transcribe" # use "off" for one-pass Whisper only
# TRANSCRIPTION_LANGUAGE="en" # ISO-639-1; use "auto" to detect
# OPENROUTER_SITE_URL="http://localhost:3000"
# OPENROUTER_APP_NAME="Stream Clipper"

# PostHog product analytics (Project settings -> Project token)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# YouTube Data API
YOUTUBE_API_KEY=""

# Local file storage root (S3/R2 migration path: swap storage adapter)
STORAGE_ROOT=./storage
# Railway: mount a persistent volume at /app/storage and set:
# STORAGE_ROOT=/app/storage

# Background worker (same Next.js process). Defaults to on in production.
# WORKER_ENABLED=1
# WORKER_SECRET=change-me
# WORKER_POLL_MS=8000
# WORKER_STALE_MS=600000
# RETENTION_TICK_HOURS=6
# Cron alternative: POST /api/worker/tick with Authorization: Bearer $WORKER_SECRET

# FFmpeg binaries (use bare names on Linux/Docker; full paths on Windows)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Small containers (Railway): limit ffmpeg RAM — enabled by default in production
# FFMPEG_LOW_MEMORY=1
# FFMPEG_THREADS=1
# FFMPEG_RENDER_PRESET=ultrafast
# RENDER_MAX_SOURCE_HEIGHT=1080
# RENDER_VERTICAL_HEIGHT=1920
# NODE_OPTIONS=--max-old-space-size=384

# yt-dlp — downloads video from stream URLs (YouTube, Twitch, Kick)
YT_DLP_PATH=yt-dlp
# Analysis-copy resolution. Defaults to 480 on production and 1080 locally.
# SOURCE_MAX_HEIGHT=480
# Optional when YouTube challenges or blocks Railway's datacenter IP:
# YT_DLP_PROXY=http://user:password@host:port
# YT_DLP_COOKIES_PATH=/app/storage/cookies.txt
# YT_DLP_COOKIES_B64=<base64-encoded Netscape cookies.txt>
# Railway/Docker: install via Dockerfile (ffmpeg + yt-dlp apt packages)
# Mount a persistent volume at /app/storage and set STORAGE_ROOT=/app/storage
# Prefer IPv4 when Twitch gql.twitch.tv DNS fails on Windows (default: on)
# YT_DLP_FORCE_IPV4=1
# YT_DLP_SOCKET_TIMEOUT=30

# --- Stripe (billing — required for subscriptions) ---
#
# Setup checklist:
#   1. Create a Stripe account: https://dashboard.stripe.com/register
#   2. Enable Managed Payments + accept ToS:
#      https://dashboard.stripe.com/settings/managed-payments
#   3. Copy API keys (use test keys while developing):
#      https://dashboard.stripe.com/test/apikeys
#   4. Run `npm run stripe:provision-catalog` to create products/prices,
#      then paste the printed STRIPE_PRICE_* lines below.
#   5. Add a webhook endpoint (production):
#      URL: https://YOUR_DOMAIN/api/stripe/webhook
#      Events: checkout.session.completed,
#              checkout.session.async_payment_succeeded,
#              checkout.session.async_payment_failed,
#              customer.subscription.updated,
#              customer.subscription.deleted
#      Copy the signing secret into STRIPE_WEBHOOK_SECRET.
#   6. Local dev webhook (optional):
#      stripe listen --forward-to localhost:3000/api/stripe/webhook
#      Use the whsec_... secret it prints for STRIPE_WEBHOOK_SECRET.
#
# Secret key — server only, never expose to the browser (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=""
#
# Publishable key — safe for client-side Stripe.js if needed later (pk_test_... or pk_live_...)
STRIPE_PUBLISHABLE_KEY=""
#
# Webhook signing secret from Dashboard → Developers → Webhooks (whsec_...)
STRIPE_WEBHOOK_SECRET=""
#
# Managed Payments on checkout (default: true). Set false only if you have not
# activated Managed Payments in the Dashboard yet.
STRIPE_MANAGED_PAYMENTS_ENABLED=true
#
# Subscription price IDs (price_...) — one per plan + billing interval.
# Generate automatically: npm run stripe:provision-catalog
# Or create manually in Dashboard → Product catalog (tax code: txcd_10103100).
#
# Creator — $19/mo, $190/yr
STRIPE_PRICE_CREATOR_MONTHLY=""
STRIPE_PRICE_CREATOR_YEARLY=""
#
# Pro — $49/mo, $490/yr
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
#
# Studio — $99/mo, $990/yr
STRIPE_PRICE_STUDIO_MONTHLY=""
STRIPE_PRICE_STUDIO_YEARLY=""

# --- Comp / unlimited access (no Stripe subscription required) ---
#
# Your email(s) — sign in at /login with no invite code needed:
# UNLIMITED_ACCESS_EMAILS="you@example.com,cofounder@example.com"
#
# Invite codes to share with beta users (email + code at /login):
# ACCESS_INVITE_CODES="beta-friend1,beta-family2"
UNLIMITED_ACCESS_EMAILS=""
ACCESS_INVITE_CODES=""

# Optional Twitch Helix fallback when yt-dlp cannot reach gql.twitch.tv
# Create an app at https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
