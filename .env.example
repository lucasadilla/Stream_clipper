# --- Supabase (recommended) ---
# Transaction pooler — use for the running app (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for Prisma migrations / db push (port 5432).
# Required on Railway: container start runs `prisma db push` via DIRECT_URL.
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Local PostgreSQL (alternative) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stream_clipper?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/stream_clipper?schema=public"

# Public site URL used for Open Graph / sitemap absolute links
# Must match your production domain (no trailing slash, no quotes)
# Railway: set the value WITHOUT quotes — e.g. https://streamclipper.stream
# not "https://streamclipper.stream"
NEXT_PUBLIC_SITE_URL="https://streamclipper.stream"

# OpenAI (direct API — optional if using OpenRouter)
OPENAI_API_KEY=""

# OpenRouter (cheaper chat + optional Whisper/embeddings; OpenAI-compatible SDK)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# OPENROUTER_CHAT_MODEL="google/gemini-2.5-flash-lite"
# OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
# OPENROUTER_WHISPER_MODEL="openai/whisper-large-v3"  # supports word/segment timestamps via verbose_json
# WHISPER_PROVIDER="openrouter"  # default when OPENROUTER_API_KEY is set; use "openai" for direct API
# OPENAI_TRANSCRIPTION_QUALITY_MODEL="gpt-4o-transcribe" # use "off" for one-pass Whisper only
# TRANSCRIPTION_LANGUAGE="en" # ISO-639-1; use "auto" to detect
# OPENROUTER_SITE_URL="http://localhost:3000"
# OPENROUTER_APP_NAME="Stream Clipper"

# PostHog product analytics (Project settings -> Project token)
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"

# YouTube Data API
YOUTUBE_API_KEY=""

# --- Social publishing (YouTube + TikTok + X + Meta) ---
# 32-byte key as base64, or any passphrase (hashed). Required in production.
# SOCIAL_TOKEN_ENCRYPTION_KEY=
#
# YouTube upload OAuth (separate from Auth.js login).
# Redirect: https://your-domain/api/social/oauth/youtube/callback
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
# YOUTUBE_REDIRECT_URI=https://streamclipper.stream/api/social/oauth/youtube/callback
#
# TikTok Content Posting API (Login Kit + video.publish / video.upload).
# Unaudited apps are limited to SELF_ONLY (private) direct posts.
# Redirect: https://your-domain/api/social/oauth/tiktok/callback
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
# TIKTOK_REDIRECT_URI=https://streamclipper.stream/api/social/oauth/tiktok/callback
#
# X (Twitter) OAuth 2.0 with PKCE — needs tweet.write + media.write.
# Redirect: https://your-domain/api/social/oauth/x/callback
# X_CLIENT_ID=
# X_CLIENT_SECRET=
# X_REDIRECT_URI=https://streamclipper.stream/api/social/oauth/x/callback
#
# Meta — one app for Facebook Pages + Instagram professional accounts.
# Redirects (can share META_REDIRECT_URI or set per-platform):
#   .../api/social/oauth/facebook/callback
#   .../api/social/oauth/instagram/callback
# META_APP_ID=
# META_APP_SECRET=
# META_REDIRECT_URI=https://streamclipper.stream/api/social/oauth/facebook/callback
# FACEBOOK_REDIRECT_URI=
# INSTAGRAM_REDIRECT_URI=
#
# Capability overrides (defaults kick in when client credentials exist):
# private_test_only | production_ready | not_configured | development_only | awaiting_review | temporarily_disabled
# YOUTUBE_PUBLISH_CAPABILITY=private_test_only
# TIKTOK_PUBLISH_CAPABILITY=private_test_only
# X_PUBLISH_CAPABILITY=development_only
# INSTAGRAM_PUBLISH_CAPABILITY=development_only
# FACEBOOK_PUBLISH_CAPABILITY=development_only
# REDDIT_PUBLISH_CAPABILITY=not_configured

# Local file storage root (S3/R2 migration path: swap storage adapter)
STORAGE_ROOT=./storage
# Railway: mount a persistent volume at /app/storage and set:
# STORAGE_ROOT=/app/storage

# Background worker (same Next.js process). Defaults to on in production.
# WORKER_ENABLED=1
# WORKER_SECRET=change-me
# WORKER_POLL_MS=2000
# WORKER_STALE_MS=600000
# RETENTION_TICK_HOURS=6
# Cron alternative: POST /api/worker/tick with Authorization: Bearer $WORKER_SECRET

# FFmpeg binaries (use bare names on Linux/Docker; full paths on Windows)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
# Small containers (Railway): limit ffmpeg RAM — enabled by default in production
# FFMPEG_LOW_MEMORY=1
# FFMPEG_THREADS=1
# Local desktop Quick Save uses stream copy (threads irrelevant). For social
# re-encodes locally, set FFMPEG_LOW_MEMORY=0 and FFMPEG_THREADS=0 (auto).
# FFMPEG_RENDER_PRESET=ultrafast
# Higher quality when burning captions (default: medium). Use slow for max clarity.
# FFMPEG_CAPTION_PRESET=medium
# RENDER_MAX_SOURCE_HEIGHT=1080
# RENDER_VERTICAL_HEIGHT=1920
# NODE_OPTIONS=--max-old-space-size=384

# --- Facecam detection (vertical 9:16 exports) ---
# Python with workers/facecam/requirements.txt installed. Defaults to "python"
# on Windows and "python3" elsewhere; point at a venv binary if you use one.
# FACECAM_PYTHON=python
# Frames are downscaled to this width before detection (default 640)
# FACECAM_ANALYSIS_WIDTH=640
# Hard kill timeout for one analysis job (default 240000 = 4 min)
# FACECAM_ANALYSIS_TIMEOUT_MS=240000
# Where downloaded detector models are cached (default ~/.cache/clipper)
# FACECAM_MODEL_DIR=

# yt-dlp — downloads video from stream URLs (YouTube, Twitch, Kick)
YT_DLP_PATH=yt-dlp
# Production Docker defaults: browser impersonation + mweb PO-token provider.
# YT_DLP_IMPERSONATE=chrome
# YT_DLP_YOUTUBE_CLIENT=mweb
# YT_DLP_POT_PROVIDER_URL=http://127.0.0.1:4416
# Analysis-copy resolution. Defaults to 480 on production and 1080 locally.
# SOURCE_MAX_HEIGHT=480
# Optional proxy when YouTube blocks Railway's datacenter IP:
# YT_DLP_PROXY=http://user:password@host:port
# Local test only: absolute path to a Netscape cookies.txt export.
# YT_DLP_COOKIES_PATH=C:/secure/youtube-cookies.txt
# Railway secret: Base64-encoded Netscape cookies.txt. The app decodes this to
# /tmp/youtube-cookies.txt with 0600 permissions. Never use NEXT_PUBLIC_* here.
# YT_DLP_COOKIES_B64=<base64-encoded Netscape cookies.txt>
# Railway/Docker: install via Dockerfile (ffmpeg + yt-dlp apt packages)
# Mount a persistent volume at /app/storage and set STORAGE_ROOT=/app/storage
# Prefer IPv4 when Twitch gql.twitch.tv DNS fails on Windows (default: on)
# YT_DLP_FORCE_IPV4=1
# YT_DLP_SOCKET_TIMEOUT=30
# Direct capture is best-effort because YouTube may block datacenter IPs even
# with current cookies. Clipper offers an upload fallback for authorized VODs.

# --- Stripe (billing — required for subscriptions) ---
#
# Setup checklist:
#   1. Create a Stripe account: https://dashboard.stripe.com/register
#   2. Enable Managed Payments + accept ToS:
#      https://dashboard.stripe.com/settings/managed-payments
#   3. Copy API keys (use test keys while developing):
#      https://dashboard.stripe.com/test/apikeys
#   4. Run `npm run stripe:provision-catalog` to create products/prices,
#      then paste the printed STRIPE_PRICE_* lines below.
#   5. Add a webhook endpoint (production):
#      URL: https://YOUR_DOMAIN/api/stripe/webhook
#      Events: checkout.session.completed,
#              checkout.session.async_payment_succeeded,
#              checkout.session.async_payment_failed,
#              customer.subscription.updated,
#              customer.subscription.deleted
#      Copy the signing secret into STRIPE_WEBHOOK_SECRET.
#   6. Local dev webhook (optional):
#      stripe listen --forward-to localhost:3000/api/stripe/webhook
#      Use the whsec_... secret it prints for STRIPE_WEBHOOK_SECRET.
#
# Secret key — server only, never expose to the browser (sk_test_... or sk_live_...)
STRIPE_SECRET_KEY=""
#
# Publishable key — safe for client-side Stripe.js if needed later (pk_test_... or pk_live_...)
STRIPE_PUBLISHABLE_KEY=""
#
# Webhook signing secret from Dashboard → Developers → Webhooks (whsec_...)
STRIPE_WEBHOOK_SECRET=""
#
# Managed Payments on checkout (default: true). Set false only if you have not
# activated Managed Payments in the Dashboard yet.
STRIPE_MANAGED_PAYMENTS_ENABLED=true
#
# Subscription price IDs (price_...) — one per plan + billing interval.
# Generate automatically: npm run stripe:provision-catalog
# Or create manually in Dashboard → Product catalog (tax code: txcd_10103100).
#
# Creator — $19/mo, $190/yr
STRIPE_PRICE_CREATOR_MONTHLY=""
STRIPE_PRICE_CREATOR_YEARLY=""
#
# Pro — $49/mo, $490/yr
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
#
# Studio — $99/mo, $990/yr
STRIPE_PRICE_STUDIO_MONTHLY=""
STRIPE_PRICE_STUDIO_YEARLY=""

# --- Comp / unlimited access (no Stripe subscription required) ---
#
# Your email(s) — sign in at /login with no invite code needed:
# UNLIMITED_ACCESS_EMAILS="you@example.com,cofounder@example.com"
#
# Invite codes to share with beta users (email + code at /login):
# ACCESS_INVITE_CODES="beta-friend1,beta-family2"
UNLIMITED_ACCESS_EMAILS=""
ACCESS_INVITE_CODES=""

# --- Auth.js (Google / Twitch / Kick / email magic link) ---
# Generate with: openssl rand -base64 32
AUTH_SECRET=""
# Public site URL used by Auth.js callbacks (same as NEXT_PUBLIC_SITE_URL)
# Must match the URL you open in the browser or Auth.js session cookies fail.
# Local: http://localhost:3000
# Production: https://streamclipper.stream
AUTH_URL="http://localhost:3000"

# Google Cloud Console → OAuth client (Web)
# Redirect URI: https://streamclipper.stream/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Twitch Developer Console → application
# Redirect URI: https://streamclipper.stream/api/auth/callback/twitch
AUTH_TWITCH_ID=""
AUTH_TWITCH_SECRET=""

# Kick developer app (OAuth)
# Redirect URI: https://streamclipper.stream/api/auth/callback/kick
AUTH_KICK_ID=""
AUTH_KICK_SECRET=""

# Resend API key for email magic links (https://resend.com)
AUTH_RESEND_KEY=""
AUTH_EMAIL_FROM="Clipper <login@streamclipper.stream>"

# --- Invite-only Creator Beta ---
# Set false to pause all Creator Beta access without deleting accounts or codes.
CREATOR_BETA_ENABLED=true
# Private owner secret for /creator-beta/admin and its code-management API.
# Use a long random value and never expose it through NEXT_PUBLIC_* variables.
CREATOR_BETA_ADMIN_SECRET=""

# Optional Twitch Helix fallback when yt-dlp cannot reach gql.twitch.tv
# Create an app at https://dev.twitch.tv/console/apps
# TWITCH_CLIENT_ID=
# TWITCH_CLIENT_SECRET=
