# --- Supabase (recommended) ---
# Transaction pooler — use for the running app (port 6543)
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection — use for Prisma migrations / db push (port 5432)
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# --- Local PostgreSQL (alternative) ---
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/stream_clipper?schema=public"
# DIRECT_URL="postgresql://postgres:postgres@localhost:5432/stream_clipper?schema=public"

# OpenAI (direct API — optional if using OpenRouter)
OPENAI_API_KEY=""

# OpenRouter (cheaper chat + optional Whisper/embeddings; OpenAI-compatible SDK)
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=""
# OPENROUTER_CHAT_MODEL="google/gemini-2.5-flash-lite"
# OPENROUTER_EMBEDDING_MODEL="openai/text-embedding-3-small"
# OPENROUTER_WHISPER_MODEL="openai/whisper-large-v3-turbo"
# WHISPER_PROVIDER="openrouter"  # openrouter | openai | auto (default: openrouter when key set)
# OPENROUTER_SITE_URL="http://localhost:3000"
# OPENROUTER_APP_NAME="Stream Clipper"

# YouTube Data API
YOUTUBE_API_KEY=""

# Local file storage root (S3/R2 migration path: swap storage adapter)
STORAGE_ROOT=./storage

# FFmpeg binaries
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe

# yt-dlp — downloads video from YouTube URL for clipping
YT_DLP_PATH=yt-dlp
