generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [vector]
}

model StreamSession {
  id                     String    @id @default(cuid())
  billingAccountId       String?
  platform               String    @default("youtube") // youtube | twitch | kick
  youtubeVideoId         String
  youtubeUrl             String
  title                  String?
  description            String?   @db.Text
  channelTitle           String?
  channelId              String?
  thumbnailUrl           String?
  liveStatus             String?
  actualStartTime        DateTime?
  scheduledStartTime     DateTime?
  concurrentViewers      Int?
  activeLiveChatId       String?
  metadataJson           Json?
  transcribeLockedAt     DateTime?
  transcribeLockedBy     String?
  lastTranscriptionError String?   @db.Text
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  chatMessages        ChatMessage[]
  eventWindows        EventWindow[]
  transcriptChunks    TranscriptChunk[]
  audioEvents         AudioEvent[]
  visualEvents        VisualEvent[]
  facecamRegions      FacecamRegion[]
  sourceMedia         SourceMedia[]
  clipSuggestions     ClipSuggestion[]
  renderJobs          RenderJob[]
  platformExportPacks PlatformExportPack[]
  platformExports     PlatformExport[]
  chatTracking        ChatTrackingState?
  liveRecording       LiveRecordingState?
  billingAccount      BillingAccount?      @relation(fields: [billingAccountId], references: [id], onDelete: SetNull)

  @@index([billingAccountId])
  @@index([youtubeVideoId])
}

model BillingAccount {
  id                   String    @id @default(cuid())
  userId               String?   @unique
  email                String?
  displayName          String?
  authProvider         String?
  stripeCustomerId     String    @unique
  stripeSubscriptionId String?   @unique
  plan                 String
  status               String    @default("incomplete")
  unlimitedAccess      Boolean   @default(false)
  betaAccess           Boolean   @default(false)
  betaGrantedAt        DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean   @default(false)
  lastSignedInAt       DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user            User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  streamSessions  StreamSession[]
  creatorBetaCode CreatorBetaCode? @relation("CreatorBetaCodeRedemption")

  @@index([status])
  @@index([plan])
  @@index([email])
}

/// Auth.js (NextAuth) identity — OAuth + email magic-link users
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  billingAccount BillingAccount?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LiveRecordingState {
  id              String        @id @default(cuid())
  streamSessionId String        @unique
  status          String        @default("idle") // idle | recording | stopped | completed
  pid             Int?
  startedAt       DateTime?
  lastSyncedAt    DateTime?
  recordedSeconds Float         @default(0)
  streamSession   StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
}

model ChatTrackingState {
  id              String        @id @default(cuid())
  streamSessionId String        @unique
  isActive        Boolean       @default(false)
  nextPageToken   String?
  pollingInterval Int           @default(5000)
  lastPolledAt    DateTime?
  startedAt       DateTime?
  streamSession   StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
}

model ChatMessage {
  id               String   @id @default(cuid())
  streamSessionId  String
  youtubeMessageId String
  authorName       String
  authorChannelId  String?
  messageText      String   @db.Text
  publishedAt      DateTime
  videoTimeSeconds Float?
  rawJson          Json?
  createdAt        DateTime @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)

  @@unique([streamSessionId, youtubeMessageId])
  @@index([streamSessionId, publishedAt])
}

model EventWindow {
  id               String                       @id @default(cuid())
  streamSessionId  String
  startTimeSeconds Float
  endTimeSeconds   Float
  type             String                       @default("chat_window")
  summary          String?                      @db.Text
  score            Float                        @default(0)
  embedding        Unsupported("vector(1536)")?
  rawData          Json?
  createdAt        DateTime                     @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)

  @@index([streamSessionId, startTimeSeconds])
  @@index([streamSessionId, score])
}

model TranscriptChunk {
  id               String                       @id @default(cuid())
  streamSessionId  String
  startTimeSeconds Float
  endTimeSeconds   Float
  text             String                       @db.Text
  embedding        Unsupported("vector(1536)")?
  rawJson          Json?
  createdAt        DateTime                     @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)

  @@index([streamSessionId, startTimeSeconds])
}

model AudioEvent {
  id               String   @id @default(cuid())
  streamSessionId  String
  startTimeSeconds Float
  endTimeSeconds   Float
  type             String
  score            Float    @default(0)
  summary          String?  @db.Text
  rawData          Json?
  createdAt        DateTime @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)

  @@index([streamSessionId, startTimeSeconds])
}

model VisualEvent {
  id               String   @id @default(cuid())
  streamSessionId  String
  startTimeSeconds Float
  endTimeSeconds   Float
  type             String
  score            Float    @default(0)
  summary          String?  @db.Text
  rawData          Json?
  createdAt        DateTime @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)

  @@index([streamSessionId, startTimeSeconds])
}

model FacecamRegion {
  id              String   @id @default(cuid())
  streamSessionId String
  x               Float
  y               Float
  width           Float
  height          Float
  confidence      Float    @default(0)
  sampleCount     Int      @default(0)
  rawData         Json?
  createdAt       DateTime @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
}

model SourceMedia {
  id               String   @id @default(cuid())
  streamSessionId  String
  originalFilename String
  filePath         String
  mimeType         String
  sizeBytes        BigInt
  durationSeconds  Float?
  isLiveRecording  Boolean  @default(false)
  width            Int?
  height           Int?
  fps              Float?
  codecInfo        Json?
  createdAt        DateTime @default(now())

  streamSession StreamSession @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
  renderJobs    RenderJob[]
}

model ClipSuggestion {
  id                  String    @id @default(cuid())
  streamSessionId     String
  title               String
  startTimeSeconds    Float
  endTimeSeconds      Float
  reason              String    @db.Text
  confidence          Float     @default(0.5)
  suggestedFormat     String    @default("9:16")
  suggestedLayout     String    @default("center_crop")
  status              String    @default("suggested")
  rawAiJson           Json?
  marketingApproved   Boolean   @default(false)
  marketingApprovedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  streamSession       StreamSession        @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
  renderJobs          RenderJob[]
  platformExportPacks PlatformExportPack[]
  platformExports     PlatformExport[]

  @@index([streamSessionId, status])
}

model CreatorBetaCode {
  id              String    @id @default(cuid())
  name            String
  /// Creator / cohort this seat was minted for (admin label)
  intendedFor     String?
  codeHash        String    @unique
  codeHint        String
  active          Boolean   @default(true)
  usedByAccountId String?   @unique
  usedAt          DateTime?
  expiresAt       DateTime?
  notes           String?   @db.Text
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  usedByAccount BillingAccount? @relation("CreatorBetaCodeRedemption", fields: [usedByAccountId], references: [id], onDelete: SetNull)

  @@index([active, expiresAt])
  @@index([createdAt])
  @@index([intendedFor])
}

model RenderJob {
  id               String    @id @default(cuid())
  streamSessionId  String
  clipSuggestionId String?
  sourceMediaId    String?
  status           String    @default("queued")
  progress         Float     @default(0)
  outputPath       String?
  errorMessage     String?   @db.Text
  layout           String    @default("center_crop")
  includeCaptions  Boolean   @default(true)
  params           Json?
  attempts         Int       @default(0)
  maxAttempts      Int       @default(3)
  lockedAt         DateTime?
  lockedBy         String?
  startedAt        DateTime?
  completedAt      DateTime?
  logs             Json?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  streamSession   StreamSession    @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
  clipSuggestion  ClipSuggestion?  @relation(fields: [clipSuggestionId], references: [id], onDelete: SetNull)
  sourceMedia     SourceMedia?     @relation(fields: [sourceMediaId], references: [id], onDelete: SetNull)
  platformExports PlatformExport[]

  @@index([streamSessionId, status])
  @@index([status, lockedAt])
  @@index([status, createdAt])
}

model PlatformExportPack {
  id               String   @id @default(cuid())
  clipSuggestionId String
  streamSessionId  String
  name             String
  status           String   @default("queued")
  errorMessage     String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  clipSuggestion ClipSuggestion   @relation(fields: [clipSuggestionId], references: [id], onDelete: Cascade)
  streamSession  StreamSession    @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)
  exports        PlatformExport[]

  @@index([clipSuggestionId, createdAt])
  @@index([streamSessionId, status])
}

model PlatformExport {
  id                 String    @id @default(cuid())
  exportPackId       String
  clipSuggestionId   String
  renderJobId        String?
  streamSessionId    String
  platform           String
  presetName         String
  status             String    @default("queued")
  progress           Int       @default(0)
  outputPath         String?
  thumbnailPath      String?
  title              String?
  caption            String?   @db.Text
  hashtags           Json      @default("[]")
  postText           String?   @db.Text
  description        String?   @db.Text
  tags               Json?
  quoteText          String?   @db.Text
  thumbnailText      String?
  pinnedComment      String?   @db.Text
  validationWarnings Json      @default("[]")
  exportSettings     Json
  width              Int?
  height             Int?
  durationSeconds    Float?
  fileSizeBytes      BigInt?
  errorMessage       String?   @db.Text
  lockedAt           DateTime?
  lockedBy           String?
  startedAt          DateTime?
  completedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  exportPack     PlatformExportPack @relation(fields: [exportPackId], references: [id], onDelete: Cascade)
  clipSuggestion ClipSuggestion     @relation(fields: [clipSuggestionId], references: [id], onDelete: Cascade)
  renderJob      RenderJob?         @relation(fields: [renderJobId], references: [id], onDelete: SetNull)
  streamSession  StreamSession      @relation(fields: [streamSessionId], references: [id], onDelete: Cascade)

  @@unique([exportPackId, platform])
  @@index([status, createdAt])
  @@index([clipSuggestionId, createdAt])
  @@index([streamSessionId, status])
}
